# ClawSecretary Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ===========================================
# REQUIRED - Minimum for Basic Functionality  
# ===========================================
# Get these from your WhatsApp Business API setup
MATON_API_KEY=your_maton_api_key_here
WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
# Generate a secure token for RSA tunnel authentication
SAAS_BRIDGE_TOKEN=generate_a_secure_random_token_here
# ===========================================
# OPTIONAL - Extended Functionality
# ===========================================
# Notion Integration (for knowledge sync)
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
# RSS and Intelligence Features  
TAVILY_API_KEY=your_tavily_api_key_here
# Calendly Integration
CALENDLY_API_KEY=your_calendly_api_key_here
# ===========================================
# OPTIONAL - Advanced Features
# ===========================================
# Google CLI Integration (for full Google services)
GOG_ACCOUNT=your_google_email_here
# Localization
USER_CITY=Your_City_Name_Here
# Default WhatsApp number for notifications
WA_DEFAULT_PHONE=your_country_code_and_number_here
# Obsidian Local Vault Path
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
# 
# 1. Required Variables:
#    - MATON_API_KEY: Sign up at https://maton.ai/ for WhatsApp Business API
#    - WA_PHONE_NUMBER_ID: Find this in your Meta for Developers dashboard
#    - SAAS_BRIDGE_TOKEN: Generate a random 32-character string
#
# 2. Quick Start Commands:
#    cp env.template .env
#    # Edit .env with your values
#    openclaw gateway run
#
# 3. After setup:
#    - Scan the QR code that appears
#    - Open the link on your phone
#    - Add to home screen
#    - Connect your accounts (Google, Notion, etc.)
#
# ===========================================
# SECURITY NOTES
# ===========================================
# - Never commit this file to version control
# - Keep your tokens secure and private
# - Rotate tokens regularly for security
# - Use strong, random values for SAAS_BRIDGE_TOKEN
# ===========================================
